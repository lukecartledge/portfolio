---
import { getCollection } from 'astro:content'
import Base from '@/layouts/Base.astro'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'

interface Props {
  title: string
  description?: string
  ogImage?: string
}

const { title, description, ogImage } = Astro.props

const siteConfigEntries = await getCollection('siteConfig')
const config = siteConfigEntries[0]?.data

const socialLinks = (config?.socialLinks ?? []).map((link: { platform: string; url: string }) => {
  const labels: Record<string, string> = {
    instagram: 'Instagram',
    github: 'GitHub',
    email: 'Email',
  }
  return {
    platform: link.platform as 'instagram' | 'github' | 'email',
    url: link.url,
    label: labels[link.platform] ?? link.platform,
  }
})
---

<Base title={title} description={description} ogImage={ogImage}>
  <Header socialLinks={socialLinks} />
  <main id="main">
    <slot />
  </main>
  <Footer />
</Base>
