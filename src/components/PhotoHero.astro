---
import type { SanityImageSource } from '@sanity/image-url'
import { urlFor, heroSrcset } from '@/lib/image'

interface Props {
  image: SanityImageSource
  alt: string
  overlay?: boolean
}

const { image, alt, overlay = false } = Astro.props

const src = urlFor(image).width(1920).quality(80).auto('format').url()
const srcset = heroSrcset(image)
---

<section class:list={['photo-hero', { 'has-overlay': overlay }]}>
  <img
    src={src}
    srcset={srcset}
    sizes="100vw"
    alt={alt}
    width="1920"
    height="1080"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  {
    overlay && (
      <div class="overlay">
        <slot />
      </div>
    )
  }
</section>

<style>
  .photo-hero {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    max-height: 50vh;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .photo-hero {
      max-height: 60vh;
    }
  }

  @media (min-width: 1024px) {
    .photo-hero {
      max-height: 70vh;
    }
  }

  .photo-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-overlay);
    color: var(--color-bg);
  }
</style>
