---
import type { SanityImageSource } from '@sanity/image-url'
import { urlFor, masonrySrcset } from '@/lib/image'

interface Props {
  image: SanityImageSource & { asset?: { _ref?: string } }
  title: string
  href?: string
  loading?: 'lazy' | 'eager'
}

const { image, title, href, loading = 'lazy' } = Astro.props

const src = urlFor(image).width(600).quality(75).auto('format').url()
const srcset = masonrySrcset(image)

const ref = (image as { asset?: { _ref?: string } })?.asset?._ref ?? ''
const dimMatch = ref.match(/-(\d+)x(\d+)[-.]/)
const naturalWidth = dimMatch ? Number(dimMatch[1]) : 800
const naturalHeight = dimMatch ? Number(dimMatch[2]) : 600
const displayWidth = 600
const displayHeight = Math.round(displayWidth * (naturalHeight / naturalWidth))
---

<figure class="photo-card" data-photo-id={href}>
  <img
    src={src}
    srcset={srcset}
    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
    alt={title}
    width={displayWidth}
    height={displayHeight}
    loading={loading}
    decoding="async"
  />
  <div class="photo-overlay">
    <span class="photo-title">{title}</span>
  </div>
</figure>

<style>
  .photo-card {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    line-height: 0;
  }

  .photo-card img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-editorial);
  }

  .photo-card:hover img {
    transform: scale(1.03);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-gradient);
    display: flex;
    align-items: flex-end;
    padding: var(--space-4);
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .photo-card:hover .photo-overlay {
    opacity: 1;
  }

  .photo-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: #ffffff;
    letter-spacing: 0.02em;
  }
</style>
