---
import ThemeToggle from '@/components/ThemeToggle.astro'

type SocialLink = {
  platform: 'instagram' | 'email' | 'github'
  url: string
  label: string
}

interface Props {
  socialLinks?: SocialLink[]
}

const { socialLinks = [] } = Astro.props

const icons: Record<string, string> = {
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>`,
  github: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
}

const navLinks = [
  { href: '/photography', label: 'Photography' },
  { href: '/about', label: 'About' },
]
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="site-name">Luke Cartledge</a>

    <nav class="nav-desktop" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        ))
      }
      {
        socialLinks.map((link) => (
          <a
            href={link.url}
            class="social-icon"
            aria-label={link.label}
            target={link.platform !== 'email' ? '_blank' : undefined}
            rel={link.platform !== 'email' ? 'noopener noreferrer' : undefined}
          >
            <Fragment set:html={icons[link.platform]} />
          </a>
        ))
      }
      <ThemeToggle />
    </nav>

    <label class="hamburger" for="mobile-nav-toggle" aria-label="Open menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </label>
  </div>
</header>

<input
  type="checkbox"
  id="mobile-nav-toggle"
  class="mobile-nav-checkbox"
  aria-hidden="true"
  tabindex="-1"
/>
<div class="mobile-nav-overlay" aria-hidden="true">
  <label class="mobile-nav-overlay-bg" for="mobile-nav-toggle"></label>
  <nav class="mobile-nav-panel" aria-label="Mobile navigation">
    <label class="mobile-nav-close" for="mobile-nav-toggle" aria-label="Close menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </label>
    <div class="mobile-nav-links">
      {
        navLinks.map((link) => (
          <a href={link.href} class="mobile-nav-link">
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="mobile-nav-social">
      {
        socialLinks.map((link) => (
          <a
            href={link.url}
            class="social-icon"
            aria-label={link.label}
            target={link.platform !== 'email' ? '_blank' : undefined}
            rel={link.platform !== 'email' ? 'noopener noreferrer' : undefined}
          >
            <Fragment set:html={icons[link.platform]} />
          </a>
        ))
      }
    </div>
    <div class="mobile-nav-theme">
      <ThemeToggle />
    </div>
  </nav>
</div>

<style>
  .mobile-nav-checkbox {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .site-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .site-name:hover {
    color: var(--color-text);
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--nav-text-size);
    font-weight: 400;
    letter-spacing: var(--nav-letter-spacing);
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  .social-icon {
    display: inline-flex;
    color: var(--color-text-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .social-icon:hover {
    color: var(--color-text);
  }

  .hamburger {
    display: flex;
    align-items: center;
    cursor: pointer;
    color: var(--color-text);
  }

  .mobile-nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-nav-overlay-bg {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0);
    cursor: pointer;
    transition: background-color var(--duration-normal) var(--ease-out);
  }

  .mobile-nav-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(80vw, 320px);
    background-color: var(--color-bg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .mobile-nav-close {
    align-self: flex-end;
    cursor: pointer;
    color: var(--color-text);
    display: flex;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .mobile-nav-link {
    font-family: var(--font-body);
    font-size: var(--nav-text-size);
    font-weight: 400;
    letter-spacing: var(--nav-letter-spacing);
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .mobile-nav-link:hover {
    color: var(--color-text);
  }

  .mobile-nav-social {
    display: flex;
    gap: var(--space-4);
    margin-top: auto;
  }

  .mobile-nav-theme {
    padding-top: var(--space-4);
  }

  .mobile-nav-checkbox:checked ~ .mobile-nav-overlay {
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav-checkbox:checked ~ .mobile-nav-overlay .mobile-nav-overlay-bg {
    background-color: rgba(0, 0, 0, 0.4);
  }

  .mobile-nav-checkbox:checked ~ .mobile-nav-overlay .mobile-nav-panel {
    transform: translateX(0);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }

    .hamburger {
      display: none;
    }
  }
</style>
