---
import { getCollection } from 'astro:content'
import PhotoDetail from '@/layouts/PhotoDetail.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import ExifMeta from '@/components/ExifMeta.astro'
import { heroSrcset, imageUrl, ogImageUrl, assetDimensions, blurPlaceholder } from '@/lib/image'
import type { ContentfulAsset } from '@/lib/image'

export async function getStaticPaths() {
  const allEntries = await getCollection('photos')

  const sorted = [...allEntries].sort(
    (a, b) => ((a.data.displayOrder as number) ?? 99) - ((b.data.displayOrder as number) ?? 99),
  )

  return sorted.map((entry, index) => {
    const prevEntry = sorted[(index - 1 + sorted.length) % sorted.length]
    const nextEntry = sorted[(index + 1) % sorted.length]

    return {
      params: { slug: entry.data.slug as string },
      props: {
        photo: entry.data,
        prevSlug: sorted.length > 1 ? (prevEntry.data.slug as string) : null,
        nextSlug: sorted.length > 1 ? (nextEntry.data.slug as string) : null,
      },
    }
  })
}

const { photo, prevSlug, nextSlug } = Astro.props

const image = photo.image as ContentfulAsset
const { width, height } = assetDimensions(image)
const blurSrc = blurPlaceholder(image)

const title = photo.title as string
const location = photo.location as string | undefined
const camera = photo.camera as string | undefined
const lens = photo.lens as string | undefined
const aperture = photo.aperture as string | undefined
const shutterSpeed = photo.shutterSpeed as string | undefined
const iso = photo.iso as string | undefined

const hasExif = camera || lens || aperture || shutterSpeed || iso

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Photography', href: '/photography' },
  { label: title },
]
---

<PhotoDetail title={title} ogImage={ogImageUrl(image)}>
  <div class="photo-detail">
    <div class="breadcrumb-wrap container">
      <Breadcrumb items={breadcrumbItems} />
    </div>

    <figure class="photo-figure">
      <div class="photo-blur-wrap">
        <img
          class="photo-blur"
          src={blurSrc}
          alt=""
          aria-hidden="true"
          width={width}
          height={height}
        />
        <img
          class="photo-full"
          src={imageUrl(image, 1024)}
          srcset={heroSrcset(image)}
          sizes="100vw"
          alt={title}
          width={width}
          height={height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </figure>

    <div class="photo-info">
      <h1 class="photo-title">{title}</h1>

      {location && <p class="photo-location">{location}</p>}

      {
        hasExif && (
          <ExifMeta
            camera={camera}
            lens={lens}
            aperture={aperture}
            shutterSpeed={shutterSpeed}
            iso={iso}
          />
        )
      }
    </div>

    {
      (prevSlug || nextSlug) && (
        <nav class="photo-nav" aria-label="Photo navigation">
          {prevSlug ? (
            <a href={`/photo/${prevSlug}`} class="photo-nav-link photo-nav-prev">
              <span aria-hidden="true">←</span>
              <span>Previous</span>
            </a>
          ) : (
            <span />
          )}
          {nextSlug ? (
            <a href={`/photo/${nextSlug}`} class="photo-nav-link photo-nav-next">
              <span>Next</span>
              <span aria-hidden="true">→</span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </div>
</PhotoDetail>

<script is:inline>
  ;(function () {
    const imgs = document.querySelectorAll('.photo-full')
    imgs.forEach(function (img) {
      if (img.complete) {
        img.classList.add('loaded')
      } else {
        img.addEventListener('load', function () {
          img.classList.add('loaded')
        })
      }
    })
  })()
</script>

<style>
  .photo-detail {
    display: flex;
    flex-direction: column;
  }

  /* Breadcrumb */
  .breadcrumb-wrap {
    padding-block: var(--space-4) var(--space-6);
  }

  /* Hero figure — full bleed with blur-up */
  .photo-figure {
    width: 100%;
    margin: 0;
    background-color: var(--color-bg-alt);
    line-height: 0;
  }

  .photo-blur-wrap {
    position: relative;
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-blur {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: blur(20px);
    transform: scale(1.1);
    z-index: 1;
  }

  .photo-full {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    max-height: 90vh;
    object-fit: contain;
    z-index: 2;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out);
  }

  .photo-full.loaded {
    opacity: 1;
  }

  /* Info section — centered column */
  .photo-info {
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: var(--space-8) var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Title — lighter weight */
  .photo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    font-weight: 400;
    color: var(--color-text-muted);
  }

  /* Location */
  .photo-location {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  /* Prev/Next navigation */
  .photo-nav {
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: 0 var(--space-16);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }

  .photo-nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      gap var(--duration-fast) var(--ease-out);
  }

  .photo-nav-link:hover {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .photo-nav-prev:hover {
    gap: var(--space-3);
  }

  .photo-nav-next:hover {
    gap: var(--space-3);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .photo-title {
      font-size: var(--text-3xl);
    }

    .photo-info {
      padding-inline: var(--space-8);
      padding-block: var(--space-12) var(--space-16);
      gap: var(--space-6);
    }

    .photo-nav {
      padding-inline: var(--space-8);
    }
  }
</style>
