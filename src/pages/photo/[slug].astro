---
import { getCollection } from 'astro:content'
import PhotoDetail from '@/layouts/PhotoDetail.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import ExifMeta from '@/components/ExifMeta.astro'
import { heroSrcset, imageUrl, ogImageUrl, assetDimensions } from '@/lib/image'
import type { ContentfulAsset } from '@/lib/image'

export async function getStaticPaths() {
  const allEntries = await getCollection('photos')

  const sorted = [...allEntries].sort(
    (a, b) => ((a.data.displayOrder as number) ?? 99) - ((b.data.displayOrder as number) ?? 99),
  )

  return sorted.map((entry, index) => {
    const prevEntry = sorted[(index - 1 + sorted.length) % sorted.length]
    const nextEntry = sorted[(index + 1) % sorted.length]

    return {
      params: { slug: entry.data.slug as string },
      props: {
        photo: entry.data,
        prevSlug: sorted.length > 1 ? (prevEntry.data.slug as string) : null,
        nextSlug: sorted.length > 1 ? (nextEntry.data.slug as string) : null,
      },
    }
  })
}

const { photo, prevSlug, nextSlug } = Astro.props

const image = photo.image as ContentfulAsset
const { width, height } = assetDimensions(image)

const title = photo.title as string
const caption = photo.caption as string | undefined
const location = photo.location as string | undefined
const dateTaken = photo.dateTaken as string | undefined
const camera = photo.camera as string | undefined
const lens = photo.lens as string | undefined
const aperture = photo.aperture as string | undefined
const shutterSpeed = photo.shutterSpeed as string | undefined
const iso = photo.iso as string | undefined
const tags = photo.tags as string[] | undefined

const hasExif = camera || lens || aperture || shutterSpeed || iso

const formattedDate = dateTaken
  ? new Date(dateTaken).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : undefined

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Photography', href: '/photography' },
  { label: title },
]
---

<PhotoDetail title={title} description={caption} ogImage={ogImageUrl(image)}>
  <div class="photo-detail">
    <div class="breadcrumb-wrap container">
      <Breadcrumb items={breadcrumbItems} />
    </div>

    <figure class="photo-figure">
      <img
        src={imageUrl(image, 1920)}
        srcset={heroSrcset(image)}
        sizes="100vw"
        alt={title}
        width={width}
        height={height}
        loading="eager"
        decoding="async"
      />
    </figure>

    <div class="photo-info">
      <h1 class="photo-title">{title}</h1>

      {
        (location || formattedDate) && (
          <p class="photo-meta">
            {location && <span class="photo-location">{location}</span>}
            {location && formattedDate && (
              <span class="photo-meta-sep" aria-hidden="true">
                ·
              </span>
            )}
            {formattedDate && <time datetime={dateTaken}>{formattedDate}</time>}
          </p>
        )
      }

      {caption && <p class="photo-caption">{caption}</p>}

      {
        hasExif && (
          <ExifMeta
            camera={camera}
            lens={lens}
            aperture={aperture}
            shutterSpeed={shutterSpeed}
            iso={iso}
          />
        )
      }

      {tags && tags.length > 0 && <p class="photo-tags">{tags.join(', ')}</p>}
    </div>

    {
      (prevSlug || nextSlug) && (
        <nav class="photo-nav" aria-label="Photo navigation">
          {prevSlug ? (
            <a href={`/photo/${prevSlug}`} class="photo-nav-link photo-nav-prev">
              <span aria-hidden="true">←</span>
              <span>Previous</span>
            </a>
          ) : (
            <span />
          )}
          {nextSlug ? (
            <a href={`/photo/${nextSlug}`} class="photo-nav-link photo-nav-next">
              <span>Next</span>
              <span aria-hidden="true">→</span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </div>
</PhotoDetail>

<style>
  .photo-detail {
    display: flex;
    flex-direction: column;
  }

  /* Breadcrumb */
  .breadcrumb-wrap {
    padding-block: var(--space-4) var(--space-6);
  }

  /* Hero figure — full bleed */
  .photo-figure {
    width: 100%;
    margin: 0;
    background-color: var(--color-bg-alt);
    line-height: 0;
  }

  .photo-figure img {
    width: 100%;
    height: auto;
    display: block;
    max-height: 90vh;
    object-fit: contain;
  }

  /* Info section — centered column */
  .photo-info {
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: var(--space-8) var(--space-12);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Title */
  .photo-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    font-weight: 700;
    color: var(--color-text);
  }

  /* Location · Date */
  .photo-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .photo-meta-sep {
    color: var(--color-border);
  }

  /* Caption */
  .photo-caption {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  /* Tags */
  .photo-tags {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Prev/Next navigation */
  .photo-nav {
    width: 100%;
    max-width: 800px;
    margin-inline: auto;
    padding-inline: var(--space-6);
    padding-block: 0 var(--space-16);
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }

  .photo-nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out),
      gap var(--duration-fast) var(--ease-out);
  }

  .photo-nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .photo-nav-prev:hover {
    gap: var(--space-3);
  }

  .photo-nav-next:hover {
    gap: var(--space-3);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .photo-title {
      font-size: var(--text-3xl);
    }

    .photo-info {
      padding-inline: var(--space-8);
      padding-block: var(--space-12) var(--space-16);
      gap: var(--space-6);
    }

    .photo-nav {
      padding-inline: var(--space-8);
    }
  }
</style>
