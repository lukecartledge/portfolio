---
import Page from '@/layouts/Page.astro';
import SocialLinks from '@/components/SocialLinks.astro';

const socialLinks = [
  { platform: 'instagram' as const, url: 'https://instagram.com/lukecartledge', label: 'Instagram' },
  { platform: 'email' as const, url: 'mailto:hello@lukecartledge.com', label: 'Email' },
  { platform: 'github' as const, url: 'https://github.com/lukecartledge', label: 'GitHub' },
];
---

<Page title="Luke Cartledge — Photography">
  <section class="hero-placeholder">
    <div class="hero-inner">
      <p class="hero-label">Landscape &amp; Travel Photography</p>
    </div>
  </section>

  <section class="bio container prose">
    <p>
      Photographer based in Switzerland, drawn to remote landscapes and the quiet
      moments between light and land. Currently building this site — photos coming soon.
    </p>
    <div class="bio-social">
      <SocialLinks links={socialLinks} />
    </div>
  </section>

  <section class="featured container">
    <h2 class="section-heading">Featured Work</h2>
    <div class="placeholder-grid">
      <div class="placeholder-card" />
      <div class="placeholder-card" />
      <div class="placeholder-card" />
      <div class="placeholder-card" />
    </div>
  </section>
</Page>

<style>
  .hero-placeholder {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    height: 50vh;
    background-color: var(--color-bg-alt);
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .hero-placeholder {
      height: 60vh;
    }
  }

  @media (min-width: 1024px) {
    .hero-placeholder {
      height: 70vh;
    }
  }

  .hero-inner {
    text-align: left;
    padding-inline: var(--space-4);
  }

  @media (min-width: 768px) {
    .hero-inner {
      padding-inline: var(--space-8);
    }
  }

  .hero-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* --- Page-load entry animations via @starting-style --- */

  .bio {
    padding-block: var(--space-32);
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-slow) var(--ease-editorial),
      transform var(--duration-slow) var(--ease-editorial);
  }

  @starting-style {
    .bio {
      opacity: 0;
      transform: translateY(1.5rem);
    }
  }

  .bio p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .bio-social {
    display: flex;
    justify-content: flex-start;
    margin-top: var(--space-8);
  }

  .featured {
    padding-block: var(--space-24) var(--space-32);
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity var(--duration-slow) var(--ease-editorial) 200ms,
      transform var(--duration-slow) var(--ease-editorial) 200ms;
  }

  @starting-style {
    .featured {
      opacity: 0;
      transform: translateY(1.5rem);
    }
  }

  .section-heading {
    margin-bottom: var(--space-12);
    font-size: var(--text-xl);
  }

  .placeholder-grid {
    display: grid;
    gap: var(--space-3);
  }

  @media (min-width: 768px) {
    .placeholder-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  .placeholder-card {
    aspect-ratio: 3 / 2;
    background-color: var(--color-bg-alt);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  /* --- Scroll-driven reveal for cards (progressive enhancement) --- */

  @supports (animation-timeline: view()) {
    @keyframes fade-up-in {
      from {
        opacity: 0;
        transform: translateY(2rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .placeholder-card {
      animation: fade-up-in var(--ease-editorial) both;
      animation-timeline: view();
      animation-range: entry 0% entry 40%;
    }
  }
</style>
