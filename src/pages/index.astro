---
import { getCollection } from 'astro:content'
import Page from '@/layouts/Page.astro'
import PhotoGrid from '@/components/PhotoGrid.astro'
import { ogImageUrl } from '@/lib/image'

const siteConfigEntries = await getCollection('siteConfig')
const config = siteConfigEntries[0]?.data

if (!config) {
  throw new Error('siteConfig not found in Sanity. Ensure at least one siteConfig document exists.')
}

const allPhotos = await getCollection('photos')
const photos = allPhotos
  .map((entry) => entry.data)
  .sort(
    (a, b) =>
      ((a as { displayOrder?: number }).displayOrder ?? 99) -
      ((b as { displayOrder?: number }).displayOrder ?? 99),
  )
  .map((p) => ({
    image: (p as { image: unknown }).image as import('@sanity/image-url').SanityImageSource & {
      asset?: { _ref?: string }
    },
    title: (p as { title: string }).title,
    slug: (p as { slug?: { current: string } }).slug?.current,
  }))

const heroPhoto = config.featuredPhotos?.[0]
const title = config.seo?.metaTitle ?? `${config.title} — ${config.tagline}`
const description = config.seo?.metaDescription ?? config.tagline
const ogImage = heroPhoto?.image ? ogImageUrl(heroPhoto.image) : undefined
---

<Page title={title} description={description} ogImage={ogImage}>
  <section class="gallery container">
    {photos.length > 0 && <PhotoGrid photos={photos} />}
  </section>
</Page>

<style>
  .gallery {
    padding-block: var(--space-4) var(--space-16);
  }
</style>
