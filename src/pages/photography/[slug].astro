---
import { getCollection } from 'astro:content'
import Page from '@/layouts/Page.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import { masonrySrcset, assetDimensions, imageUrl, ogImageUrl } from '@/lib/image'
import type { ContentfulAsset } from '@/lib/image'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const allCollections = await getCollection('photoCollections')

  return allCollections.map((collection) => ({
    params: { slug: collection.data.slug as string },
    props: { collection: collection.data },
  }))
}

const { collection } = Astro.props

const title = collection.title as string
const description = collection.description as string | undefined
const location = collection.location as string | undefined

const coverPhotoRef = collection.coverPhoto as { fields: Record<string, unknown> }
const coverImage = coverPhotoRef.fields.image as ContentfulAsset

const photoRefs = (collection.photos as Array<{ fields: Record<string, unknown> }>) ?? []

const photos = photoRefs.map((photoRef) => ({
  image: photoRef.fields.image as ContentfulAsset,
  title: photoRef.fields.title as string,
  slug: photoRef.fields.slug as string,
}))

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: 'Photography', href: '/photography' },
  { label: title },
]

const ogImage = ogImageUrl(coverImage)
---

<Page title={`${title} — Photography — Luke Cartledge`} ogImage={ogImage}>
  <section class="collection container">
    <Breadcrumb items={breadcrumb} />

    <header class="collection-header">
      <h1 class="collection-title">{title}</h1>
      {description && <p class="collection-description">{description}</p>}
      <div class="collection-meta">
        {location && <span class="meta-location">{location}</span>}
        <span class="meta-count">{photos.length} {photos.length === 1 ? 'photo' : 'photos'}</span>
      </div>
    </header>

    {
      photos.length > 0 && (
        <div class="collection-grid">
          {photos.map((photo, index) => {
            const src = imageUrl(photo.image, 600, 75)
            const srcset = masonrySrcset(photo.image)
            const { width: naturalWidth, height: naturalHeight } = assetDimensions(photo.image)
            const displayWidth = 600
            const displayHeight = Math.round(displayWidth * (naturalHeight / naturalWidth))

            return (
              <div class="collection-grid-item">
                <a href={`/photo/${photo.slug}`} class="photo-link">
                  <figure class="photo-card">
                    <img
                      src={src}
                      srcset={srcset}
                      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                      alt={photo.title}
                      width={displayWidth}
                      height={displayHeight}
                      loading={index < 6 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                    <div class="photo-overlay">
                      <span class="photo-title">{photo.title}</span>
                    </div>
                  </figure>
                </a>
              </div>
            )
          })}
        </div>
      )
    }
  </section>
</Page>

<script is:inline>
  ;(function () {
    const items = document.querySelectorAll('.collection-grid-item')
    if (!items.length || !('IntersectionObserver' in window)) {
      items.forEach(function (el) {
        el.classList.add('revealed')
      })
      return
    }

    const staggerDelay = 80

    const observer = new IntersectionObserver(
      function (entries) {
        const toReveal = []
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            toReveal.push(entry.target)
            observer.unobserve(entry.target)
          }
        })

        toReveal
          .sort(function (a, b) {
            return a.getBoundingClientRect().top - b.getBoundingClientRect().top
          })
          .forEach(function (el, i) {
            el.style.transitionDelay = i * staggerDelay + 'ms'
            requestAnimationFrame(function () {
              el.classList.add('revealed')
            })
          })
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
    )

    items.forEach(function (el) {
      observer.observe(el)
    })
  })()
</script>

<style>
  .collection {
    padding-block: var(--space-4) var(--space-16);
  }

  .collection-header {
    margin-block: var(--space-6) var(--space-8);
  }

  .collection-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .collection-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: var(--max-prose);
    margin-bottom: var(--space-3);
  }

  .collection-meta {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .meta-location::before {
    content: '📍 ';
  }

  /* Masonry grid — CSS columns */
  .collection-grid {
    column-count: 1;
    column-gap: var(--gallery-gap);
  }

  .collection-grid-item {
    break-inside: avoid;
    display: inline-block;
    width: 100%;
    margin-bottom: var(--gallery-gap);
    opacity: 0;
    filter: blur(8px);
    transform: translateY(16px);
    transition:
      opacity var(--duration-slow) var(--ease-out),
      filter var(--duration-slow) var(--ease-out),
      transform var(--duration-slow) var(--ease-out);
  }

  .collection-grid-item.revealed {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  .photo-link {
    display: block;
    text-decoration: none;
  }

  .photo-card {
    position: relative;
    overflow: hidden;
    line-height: 0;
    margin: 0;
  }

  .photo-card img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-editorial);
  }

  .photo-link:hover .photo-card img {
    transform: scale(1.03);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay-gradient);
    display: flex;
    align-items: flex-end;
    padding: var(--space-4);
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .photo-link:hover .photo-overlay {
    opacity: 1;
  }

  .photo-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: #ffffff;
    letter-spacing: 0.02em;
  }

  @media (min-width: 640px) {
    .collection-grid {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .collection-grid {
      column-count: 3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-grid-item {
      opacity: 1;
      filter: none;
      transform: none;
      transition: none;
    }
  }
</style>
